{
  "manifest_version": 3,
  "name": "ChatSweep",
  "version": "0.1.0",
  "description": "Selectively clean up ChatGPT chats with an API-backed bulk action UI.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "ChatSweep"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-bridge.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_start"
    }
  ]
}
